global:
  scrape_interval:     15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: 'instance1-node'
    static_configs:
      - targets: ['172.31.4.204:{{ node_exporter_port }}']
        labels:
          instance: 'K3s-Server'
          env: 'production'

  - job_name: 'instance2-jenkins'
    static_configs:
      - targets: ['172.31.9.189:{{ node_exporter_port }}']
        labels:
          instance: 'Jenkins-Server'
          env: 'production'

  - job_name: 'instance3-monitoring'
    static_configs:
      - targets: ['localhost:{{ node_exporter_port }}']
        labels:
          instance: 'Monitoring-Server'
          env: 'production'
